{
  "name": "cluckingham-guard",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "license": "SEE LICENSE IN LICENSE.txt",
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "lint": "npm run lint -w client"
  },
  "dependencies": {
    "mongodb": "^6.19.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
